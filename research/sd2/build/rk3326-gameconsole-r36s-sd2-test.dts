	chosen {
		stdout-path = "serial2:115200n8";
	};

	backlight {
		compatible = "pwm-backlight";
		power-supply = <0xa6>;
		pwms = <0xa7 0x00 0x61a8 0x00>;
		brightness-levels = <0x00 0x01 0x02 0x03 0x04 0x05 0x06 0x07 0x08 0x09 0x0a 0x0b 0x0c 0x0d 0x0e 0x0f 0x10 0x11 0x12 0x13 0x14 0x15 0x16 0x17 0x18 0x19 0x1a 0x1b 0x1c 0x1d 0x1e 0x1f 0x20 0x21 0x22 0x23 0x24 0x25 0x26 0x27 0x28 0x29 0x2a 0x2b 0x2c 0x2d 0x2e 0x2f 0x30 0x31 0x32 0x33 0x34 0x35 0x36 0x37 0x38 0x39 0x3a 0x3b 0x3c 0x3d 0x3e 0x3f 0x40 0x41 0x42 0x43 0x44 0x45 0x46 0x47 0x48 0x49 0x4a 0x4b 0x4c 0x4d 0x4e 0x4f 0x50 0x51 0x52 0x53 0x54 0x55 0x56 0x57 0x58 0x59 0x5a 0x5b 0x5c 0x5d 0x5e 0x5f 0x60 0x61 0x62 0x63 0x64 0x65 0x66 0x67 0x68 0x69 0x6a 0x6b 0x6c 0x6d 0x6e 0x6f 0x70 0x71 0x72 0x73 0x74 0x75 0x76 0x77 0x78 0x79 0x7a 0x7b 0x7c 0x7d 0x7e 0x7f 0x80 0x81 0x82 0x83 0x84 0x85 0x86 0x87 0x88 0x89 0x8a 0x8b 0x8c 0x8d 0x8e 0x8f 0x90 0x91 0x92 0x93 0x94 0x95 0x96 0x97 0x98 0x99 0x9a 0x9b 0x9c 0x9d 0x9e 0x9f 0xa0 0xa1 0xa2 0xa3 0xa4 0xa5 0xa6 0xa7 0xa8 0xa9 0xaa 0xab 0xac 0xad 0xae 0xaf 0xb0 0xb1 0xb2 0xb3 0xb4 0xb5 0xb6 0xb7 0xb8 0xb9 0xba 0xbb 0xbc 0xbd 0xbe 0xbf 0xc0 0xc1 0xc2 0xc3 0xc4 0xc5 0xc6 0xc7 0xc8 0xc9 0xca 0xcb 0xcc 0xcd 0xce 0xcf 0xd0 0xd1 0xd2 0xd3 0xd4 0xd5 0xd6 0xd7 0xd8 0xd9 0xda 0xdb 0xdc 0xdd 0xde 0xdf 0xe0 0xe1 0xe2 0xe3 0xe4 0xe5 0xe6 0xe7 0xe8 0xe9 0xea 0xeb 0xec 0xed 0xee 0xef 0xf0 0xf1 0xf2 0xf3 0xf4 0xf5 0xf6 0xf7 0xf8 0xf9 0xfa 0xfb 0xfc 0xfd 0xfe 0xff>;
		default-brightness-level = <0x80>;
		phandle = <0x93>;
	};

	gpio-keys-vol {
		compatible = "gpio-keys";
		autorepeat;
		pinctrl-0 = <0xa8>;
		pinctrl-names = "default";

		button-vol-down {
			gpios = <0xa9 0x01 0x01>;
			label = "VOLUMEDOWN";
			linux,code = <0x72>;
		};

		button-volume-up {
			gpios = <0xa9 0x00 0x01>;
			label = "VOLUMEUP";
			linux,code = <0x73>;
		};
	};

	battery {
		compatible = "simple-battery";
		charge-full-design-microamp-hours = <0x30d400>;
		charge-term-current-microamp = <0x4e200>;
		constant-charge-current-max-microamp = <0x1e8480>;
		constant-charge-voltage-max-microvolt = <0x401640>;
		factory-internal-resistance-micro-ohms = <0x2bf20>;
		voltage-max-design-microvolt = <0x3e8fa0>;
		voltage-min-design-microvolt = <0x3567e0>;
		ocv-capacity-celsius = <0x14>;
		ocv-capacity-table-0 = <0x3dc066 0x64 0x3d1080 0x5f 0x3c8b9c 0x5a 0x3bd04e 0x55 0x3b5542 0x50 0x3aed5a 0x4b 0x3a76f4 0x46 0x39f85a 0x41 0x397f7e 0x3c 0x392772 0x37 0x38dd12 0x32 0x38a28e 0x2d 0x386850 0x28 0x383d1c 0x23 0x381346 0x1e 0x37e4ca 0x19 0x37afbe 0x14 0x37783c 0x0f 0x373098 0x0a 0x36d0f8 0x05 0x36899a 0x00>;
		phandle = <0x59>;
	};

	rk817-sound {
		compatible = "simple-audio-card";
		simple-audio-card,name = "rk817_int";
		simple-audio-card,format = "i2s";
		simple-audio-card,hp-det-gpio = <0xa9 0x16 0x00>;
		simple-audio-card,mclk-fs = <0x100>;
		simple-audio-card,widgets = "Microphone\0Mic Jack\0Headphone\0Headphones\0Speaker\0Speaker";
		simple-audio-card,routing = "MICL\0Mic Jack\0Headphones\0HPOL\0Headphones\0HPOR\0Speaker\0SPKO";

		simple-audio-card,codec {
			sound-dai = <0xaa>;
		};

		simple-audio-card,cpu {
			sound-dai = <0xab>;
		};
	};

	vccsys {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v8_sys";
		regulator-always-on;
		regulator-min-microvolt = <0x39fbc0>;
		regulator-max-microvolt = <0x39fbc0>;
		phandle = <0x58>;
	};

	archr,device_switch {
		r33s = "rk3326-gameconsole-r33s";
		r36s = "rk3326-gameconsole-r36s";
		rgb10x = "rk3326-powkiddy-rgb10x";
		this = "r36s";
	};

	gpio-leds {
		compatible = "gpio-leds";
		pinctrl-names = "default";
		pinctrl-0 = <0xac>;

		led-0 {
			color = <0x01>;
			function = "status";
			gpios = <0xa9 0x0d 0x00>;
			default-state = "off";
		};
	};

	odroidgo3-joypad {
		compatible = "odroidgo3-joypad";
		pwms = <0xad 0x00 0xbebc200 0x00>;
		pwm-names = "enable";
		rumble-boost-weak = <0x00>;
		rumble-boost-strong = <0x00>;
		joypad-name = "r36s_Gamepad";
		joypad-product = <0x1188>;
		joypad-revision = <0x188>;
		status = "okay";
		pinctrl-names = "default";
		pinctrl-0 = <0xae>;
		pinctrl-1 = <0x66>;
		io-channel-names = "amux_adc";
		io-channels = <0xaf 0x01>;
		amux-count = <0x04>;
		amux-a-gpios = <0x80 0x0b 0x01>;
		amux-b-gpios = <0x80 0x08 0x01>;
		amux-en-gpios = <0x80 0x0d 0x01>;
		button-adc-scale = <0x02>;
		button-adc-deadzone = <0x40>;
		button-adc-fuzz = <0x20>;
		button-adc-flat = <0x20>;
		abs_x-p-tuning = <0xc8>;
		abs_x-n-tuning = <0xc8>;
		abs_y-p-tuning = <0xc8>;
		abs_y-n-tuning = <0xc8>;
		abs_rx-p-tuning = <0xc8>;
		abs_rx-n-tuning = <0xc8>;
		abs_ry-p-tuning = <0xc8>;
		abs_ry-n-tuning = <0xc8>;
		poll-interval = <0x0a>;
		invert-absx;
		invert-absy;
		phandle = <0x133>;

		sw1 {
			gpios = <0xb0 0x0c 0x01>;
			label = "GPIO DPAD-UP";
			linux,code = <0x220>;
		};

		sw2 {
			gpios = <0xb0 0x0d 0x01>;
