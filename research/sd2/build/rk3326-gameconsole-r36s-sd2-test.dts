				rockchip,pins = <0x03 0x03 0x03 0x9c 0x03 0x05 0x03 0x9c 0x03 0x07 0x03 0x9c 0x03 0x08 0x03 0x9c 0x03 0x09 0x03 0x9c 0x03 0x0c 0x03 0x9c 0x03 0x0e 0x03 0x9c 0x03 0x0f 0x03 0x9c 0x03 0x19 0x03 0x9c 0x03 0x1a 0x03 0x9c 0x03 0x1b 0x03 0x9c 0x03 0x18 0x03 0x9c>;
